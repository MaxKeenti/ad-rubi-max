rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userIsActive(userData) {
      return (!userData.keys().hasAny(["disabledAt"]) || userData.disabledAt == null)
        && (!userData.keys().hasAny(["retiredAt"]) || userData.retiredAt == null);
    }

    function isActiveUser() {
      return isSignedIn()
        && exists(currentUserPath())
        && userIsActive(get(currentUserPath()).data);
    }

    function isAdmin() {
      return isActiveUser()
        && get(currentUserPath()).data.role == "admin";
    }

    function isOwnerWithinPurchaseEditWindow() {
      return isActiveUser()
        && resource.data.createdBy == request.auth.uid
        && resource.data.deletedAt == null
        && request.time - resource.data.serverWrittenAt < duration.value(24, 'h');
    }

    function purchaseCreateIsByCaller() {
      return isActiveUser()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.serverWrittenAt == request.time
        && request.resource.data.deletedAt == null
        && request.resource.data.deletedBy == null;
    }

    function purchaseOwnerAllowedChanges() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly([
          "supplierId",
          "supplierNoteFreeform",
          "quantityTons",
          "pricePerTonCentavos",
          "date",
          "dateKey",
          "deletedAt",
          "deletedBy"
        ])
        && (!changed.hasAny(["deletedAt", "deletedBy"])
          || (request.resource.data.deletedAt is timestamp
            && request.resource.data.deletedBy == request.auth.uid));
    }

    function userClientAllowedChanges() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "displayName"
      ]);
    }

    function validUserRole(role) {
      return role == "admin" || role == "operator";
    }

    function adminUserCreateAllowed() {
      return isAdmin()
        && request.resource.data.keys().hasOnly([
          "email",
          "displayName",
          "role",
          "accountCreatedAt",
          "disabledAt",
          "retiredAt",
          "promotedFromUid"
        ])
        && request.resource.data.keys().hasAll([
          "email",
          "displayName",
          "role",
          "accountCreatedAt",
          "disabledAt",
          "retiredAt"
        ])
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && validUserRole(request.resource.data.role)
        && request.resource.data.accountCreatedAt == request.time
        && request.resource.data.disabledAt == null
        && request.resource.data.retiredAt == null
        && (!request.resource.data.keys().hasAny(["promotedFromUid"])
          || request.resource.data.promotedFromUid is string);
    }

    function adminUserRetirementAllowed() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isAdmin()
        && resource.data.role == "operator"
        && request.resource.data.role == resource.data.role
        && request.resource.data.email == resource.data.email
        && changed.hasOnly([
          "disabledAt",
          "retiredAt",
          "promotedToUid"
        ])
        && request.resource.data.disabledAt == request.time
        && request.resource.data.retiredAt == request.time
        && request.resource.data.promotedToUid is string;
    }

    match /users/{uid} {
      allow read: if isActiveUser() && (request.auth.uid == uid || isAdmin());
      allow create: if adminUserCreateAllowed();
      allow update: if isActiveUser()
        && (
          ((request.auth.uid == uid || isAdmin()) && userClientAllowedChanges())
          || adminUserRetirementAllowed()
        );
      allow delete: if false;
    }

    match /suppliers/{id} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /purchases/{id} {
      allow read: if isActiveUser();
      allow create: if purchaseCreateIsByCaller();
      allow update: if isAdmin()
        || (isOwnerWithinPurchaseEditWindow()
          && purchaseOwnerAllowedChanges());
      allow delete: if isAdmin()
        || isOwnerWithinPurchaseEditWindow();
    }
  }
}
