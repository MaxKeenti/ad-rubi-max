rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function validSeveridad(severidad) {
      return severidad == "leve"
        || severidad == "moderado"
        || severidad == "severo";
    }

    function descripcionValida(data) {
      return !data.keys().hasAny(["descripcion"])
        || (data.descripcion is string && data.descripcion.size() <= 200);
    }

    function severidadValida(data) {
      return !data.keys().hasAny(["severidad"])
        || (data.severidad is string && validSeveridad(data.severidad));
    }

    function reporteCreateTieneFormaValida() {
      let data = request.resource.data;
      return data.keys().hasOnly([
          "lat",
          "lng",
          "geohash",
          "accuracyMeters",
          "severidad",
          "descripcion",
          "fotoPath",
          "fotoUrl",
          "createdBy",
          "confirmCount",
          "serverWrittenAt"
        ])
        && data.keys().hasAll([
          "lat",
          "lng",
          "geohash",
          "accuracyMeters",
          "fotoPath",
          "fotoUrl",
          "createdBy",
          "confirmCount",
          "serverWrittenAt"
        ])
        && data.lat is number
        && data.lng is number
        && data.geohash is string
        && data.accuracyMeters is number
        && data.fotoPath is string
        && data.fotoUrl is string
        && data.createdBy == request.auth.uid
        && data.confirmCount == 0
        && data.serverWrittenAt == request.time
        && severidadValida(data)
        && descripcionValida(data);
    }

    function noEstaEliminado() {
      return !resource.data.keys().hasAny(["deletedAt"])
        || resource.data.deletedAt == null;
    }

    function softDeleteValido() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSignedIn()
        && noEstaEliminado()
        && resource.data.createdBy == request.auth.uid
        && resource.data.serverWrittenAt is timestamp
        && request.time < resource.data.serverWrittenAt + duration.value(24, 'h')
        && changed.hasOnly(["deletedAt", "deletedBy"])
        && changed.hasAll(["deletedAt", "deletedBy"])
        && request.resource.data.deletedAt == request.time
        && request.resource.data.deletedBy == request.auth.uid;
    }

    function incrementoConfirmCountValido() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSignedIn()
        && noEstaEliminado()
        && changed.hasOnly(["confirmCount"])
        && changed.hasAll(["confirmCount"])
        && request.resource.data.confirmCount == resource.data.confirmCount + 1;
    }

    function confirmacionCreateValida(uid) {
      let data = request.resource.data;
      return isSignedIn()
        && uid == request.auth.uid
        && data.keys().hasOnly(["confirmedAt"])
        && data.keys().hasAll(["confirmedAt"])
        && data.confirmedAt == request.time;
    }

    match /reportes/{reporteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && reporteCreateTieneFormaValida();

      // Accepted v1 gap: a hostile client can increment confirmCount
      // without creating reportes/{id}/confirmaciones/{uid} in the same
      // batch. Hardening this requires getAfter() to verify the sibling
      // confirmation document after commit; deferred because the v1 impact
      // is limited to inflated incidence counts.
      allow update: if softDeleteValido() || incrementoConfirmCountValido();
      allow delete: if false;

      match /confirmaciones/{uid} {
        allow read: if isSignedIn();
        allow create: if confirmacionCreateValida(uid);
        allow update, delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
